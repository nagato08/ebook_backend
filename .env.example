# ============================================================
# EbookGen Backend — variables d'environnement (exemple)
# Copier en .env et remplir. NE JAMAIS commiter le vrai .env.
# ============================================================

# --- App ---
# En Docker, DATABASE_URL est surchargee par docker-compose (service db).
DATABASE_URL="postgresql://ebook:CHANGE_ME@db:5432/ebook?schema=public"
PORT=3001
JWT_SECRET="CHANGE_ME_secret_long_et_aleatoire"
JWT_EXPIRES_IN="30d"
# URL publique du frontend (prod: https://app.ton-domaine)
FRONTEND_URL="http://localhost:3000"

# --- Email (Resend) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@ton-domaine"

# --- Generation IA (n8n) ---
N8N_WEBHOOK_URL="https://n8n.tadjo.dev/webhook/generate-book"
N8N_WEBHOOK_TOKEN=""
# Cout du DEBLOCAGE d'un livre (generation gratuite).
UNLOCK_COST_CREDITS=20

# --- Niche analyzer (Groq) ---
# Cle Groq (gsk_...). Vide -> analyse mock.
GROQ_API_KEY=""
N8N_NICHE_WEBHOOK_URL=""

# --- Export PDF (Puppeteer) ---
# En Docker, surcharge par compose -> /usr/bin/chromium.
PUPPETEER_EXECUTABLE_PATH=""

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://api.ton-domaine/auth/google/callback"

# --- Paiement : provider actif (campay | geniuspay) ---
PAYMENT_PROVIDER="geniuspay"

# --- GeniusPay ---
# sandbox: pk_sandbox_/sk_sandbox_ | prod (apres KYC): pk_live_/sk_live_
GENIUSPAY_BASE_URL="https://pay.genius.ci/api/v1"
GENIUSPAY_API_KEY=""
GENIUSPAY_API_SECRET=""
GENIUSPAY_SUCCESS_URL="https://app.ton-domaine/dashboard/credits?status=ok"
GENIUSPAY_ERROR_URL="https://app.ton-domaine/dashboard/credits?status=ko"
# whsec_... (dashboard GeniusPay) — verif signature webhook. Vide -> skip (sandbox).
GENIUSPAY_WEBHOOK_SECRET=""
